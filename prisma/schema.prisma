generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // SUPER_ADMIN | ADMIN | MANAGER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  phone     String?
  cpf       String?   @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  addresses Address[]
  orders    Order[]
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Casa")
  zipCode    String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  orders     Order[]
}

// Shirt Bases (e.g. "Camiseta Oversized Premium")
model ShirtBase {
  id           String             @id @default(cuid())
  name         String
  type         String             // OVERSIZED | CAMISETA
  basePrice    Float
  active       Boolean            @default(true)
  imageUrl     String?
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  colors       BaseColor[]
  combinations ShirtCombination[]
}

model BaseColor {
  id           String             @id @default(cuid())
  baseId       String
  base         ShirtBase          @relation(fields: [baseId], references: [id], onDelete: Cascade)
  name         String
  hex          String
  active       Boolean            @default(true)
  stock        StockItem[]
  combinations ShirtCombination[]
}

model StockItem {
  id        String    @id @default(cuid())
  colorId   String
  color     BaseColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int       @default(0)
  updatedAt DateTime  @updatedAt
}

model Stamp {
  id           String             @id @default(cuid())
  name         String
  slug         String             @unique
  category     String?
  imageUrl     String
  thumbnailUrl String?
  extraPrice   Float              @default(0)
  allowedFor   String             @default("BOTH") // OVERSIZED | CAMISETA | BOTH
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  combinations ShirtCombination[]
}

model ShirtCombination {
  id           String    @id @default(cuid())
  baseId       String
  base         ShirtBase @relation(fields: [baseId], references: [id])
  colorId      String
  color        BaseColor @relation(fields: [colorId], references: [id])
  stampId      String?
  stamp        Stamp?    @relation(fields: [stampId], references: [id])
  imageFront   String?   // mockup: front view
  imageBack    String?   // mockup: back view
  imageUrl     String?   // legacy/generic fallback
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Non-customizable products (DryFit, 3D, Geek) + Flash Sale
model Product {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  type            String           // DRYFIT | PRODUTO_3D | GEEK
  description     String?
  price           Float
  originalPrice   Float?
  material        String?
  subcategory     String?
  isNew           Boolean          @default(false)
  isFeatured      Boolean          @default(false)
  active          Boolean          @default(true)
  rating          Float            @default(5.0)
  reviewCount     Int              @default(0)
  sortOrder       Int              @default(0)
  // Flash Sale
  isFlashSale     Boolean          @default(false)
  flashSalePrice  Float?
  flashSaleEndsAt DateTime?
  // Card images
  imageUrl        String?          // primary card image
  hoverImageUrl   String?          // hover card image
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      String?
  colorHex   String?
  size       String?
  stock      Int         @default(0)
  active     Boolean     @default(true)
  orderItems OrderItem[]
}

model Kit {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  minQty      Int       @default(10)
  priceFrom   Float
  imageUrl    String?
  audience    String?
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items       KitItem[]
}

model KitItem {
  id    String @id @default(cuid())
  kitId String
  kit   Kit    @relation(fields: [kitId], references: [id], onDelete: Cascade)
  label String
}

model Order {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  customerId      String?
  customer        Customer?            @relation(fields: [customerId], references: [id])
  addressId       String?
  address         Address?             @relation(fields: [addressId], references: [id])
  status          String               @default("CREATED")
  // Status flow: CREATED → PAYMENT_PENDING → PAYMENT_APPROVED → IN_PREPARATION → PRODUCED → AWAITING_SHIPMENT → SHIPPED → IN_TRANSIT → DELIVERED | CANCELLED
  paymentStatus   String               @default("PENDING")
  // PENDING | APPROVED | REJECTED | REFUNDED
  paymentMethod   String?
  paymentId       String?              // Mercado Pago payment_id (future)
  paymentData     String?              // JSON with MP payment details (future)
  subtotal        Float
  shippingCost    Float                @default(0)
  discount        Float                @default(0)
  total           Float
  notes           String?              // customer notes
  internalNotes   String?              // admin internal notes
  trackingCode    String?
  carrier         String?              // shipping carrier name
  estimatedDelivery String?            // estimated delivery date string
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  // Guest checkout data
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  guestCpf        String?
  guestZipCode    String?
  guestStreet     String?
  guestNumber     String?
  guestComplement String?
  guestDistrict   String?
  guestCity       String?
  guestState      String?
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdBy String   @default("system") // system | admin | customer
  createdAt DateTime @default(now())
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id])
  productId      String?
  product        Product?        @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  // Custom shirt fields
  shirtBaseId    String?
  shirtBaseName  String?
  stampId        String?
  stampName      String?
  stampSlug      String?
  isCustomShirt  Boolean         @default(false)
  previewImage   String?         // combination photo URL
  // Common fields
  colorHex       String?
  colorName      String?
  size           String?
  quantity       Int
  unitPrice      Float
  totalPrice     Float
  productName    String
  productImage   String?
}

// Shipping configuration (admin-managed)
model ShippingConfig {
  id                   String   @id @default(cuid())
  originZipCode        String   @default("01001000")
  fixedShippingEnabled Boolean  @default(true)
  fixedShippingValue   Float    @default(19.90)
  freeShippingAbove    Float    @default(199.90)
  productionDaysStd    Int      @default(7)   // standard items
  productionDaysCustom Int      @default(12)  // custom printed items
  updatedAt            DateTime @updatedAt
}
