# PostgreSQL connection string (e.g. from Neon, Supabase, Railway, or Vercel Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# JWT secret for customer authentication (generate a strong random string)
JWT_SECRET=

# JWT secret for admin authentication (generate a strong random string)
ADMIN_JWT_SECRET=

# Vercel Blob — for image uploads in production
# Create a Blob Store in your Vercel dashboard → Storage → Blob
# Then connect it to your project; the token is auto-injected
BLOB_READ_WRITE_TOKEN=

# WhatsApp number with country code (no spaces or special chars)
NEXT_PUBLIC_WHATSAPP_NUMBER=5534998275292

# Node environment (do NOT set in Vercel - it's automatic)
# NODE_ENV=production
